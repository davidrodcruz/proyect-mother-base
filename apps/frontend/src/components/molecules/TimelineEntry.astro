---
import Badge from '../atoms/Badge.astro';

interface Props {
  company: string;
  role: string;
  period: { start: string; end: string };
  responsibilities: string[];
  technologies: string[];
  achievements: string[];
  index: number;
}

const { company, role, period, responsibilities, technologies, achievements, index } = Astro.props;

const isEven = index % 2 === 0;

function formatDate(dateStr: string) {
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}
---

<div class={`relative flex flex-col md:flex-row items-start ${isEven ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
  {/* Timeline dot */}
  <div class="absolute left-0 md:left-1/2 w-3 h-3 bg-accent rounded-full transform -translate-x-[5px] md:-translate-x-1.5 mt-6 z-10 shadow-[0_0_10px_rgba(147,198,208,0.5)]" />

  {/* Content */}
  <div class={`w-full md:w-1/2 ${isEven ? 'md:pr-12' : 'md:pl-12'} pl-8 md:pl-0`}>
    <div class="bg-card backdrop-blur-sm rounded-lg hud-border p-6 hover:shadow-[0_0_15px_rgba(147,198,208,0.15)] transition-all">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-meta text-sm tracking-[0.2em] uppercase font-heading">
          {formatDate(period.start)} — {period.end === 'present' ? 'Present' : formatDate(period.end)}
        </span>
      </div>

      <h3 class="font-heading text-2xl font-bold text-headline mb-1">{role}</h3>
      <p class="text-body text-base mb-4">{company}</p>

      {responsibilities.length > 0 && (
        <div class="mb-4">
          <h4 class="text-meta text-sm tracking-wider uppercase mb-2 font-heading">Responsibilities</h4>
          <ul class="space-y-1.5">
            {responsibilities.map((resp: string) => (
              <li class="text-body text-base flex items-start gap-2">
                <span class="text-border mt-1">▸</span>
                <span>{resp}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      {achievements.length > 0 && (
        <div class="mb-4">
          <h4 class="text-meta text-sm tracking-wider uppercase mb-2 font-heading">Key Achievements</h4>
          <ul class="space-y-1.5">
            {achievements.map((achievement: string) => (
              <li class="text-body text-base flex items-start gap-2">
                <span class="text-accent mt-1">★</span>
                <span>{achievement}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      <div class="flex flex-wrap gap-1.5">
        {technologies.map((tech: string) => (
          <Badge text={tech} variant="accent" size="sm" />
        ))}
      </div>
    </div>
  </div>
</div>
