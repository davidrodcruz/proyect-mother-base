---
interface Props {
  text: string;
  variant?: 'accent' | 'meta' | 'danger';
  size?: 'sm' | 'md' | 'lg';
}

const { text, variant = 'accent', size = 'md' } = Astro.props;

const sizeClasses = {
  sm: 'px-2 py-0.5 text-xs',
  md: 'px-3 py-1 text-sm',
  lg: 'px-4 py-1.5 text-base',
};

const variantClasses = {
  accent: 'border-accent/40 text-accent hover:bg-accent/10',
  meta: 'border-meta/40 text-meta hover:bg-meta/10',
  danger: 'border-danger/40 text-danger hover:bg-danger/10',
};
---

<span
  class={`inline-flex items-center font-heading tracking-wider uppercase border rounded ${sizeClasses[size]} ${variantClasses[variant]} transition-colors`}
>
  {text}
</span>
